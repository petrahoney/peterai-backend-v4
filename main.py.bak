from fastapi import FastAPI, HTTPException, Request
from pydantic import BaseModel
import httpx
import os
from dotenv import load_dotenv
import asyncio

load_dotenv()

app = FastAPI()
ANTHROPIC_API_KEY = os.getenv("ANTHROPIC_API_KEY")

class ChatRequest(BaseModel):
    message: str

async def call_claude(message: str) -> str:
    timeout = httpx.Timeout(60.0, connect=10.0)
    max_retries = 3
    
    for attempt in range(max_retries):
        try:
            async with httpx.AsyncClient(timeout=timeout) as client:
                response = await client.post(
                    "https://api.anthropic.com/v1/messages",
                    headers={"x-api-key": ANTHROPIC_API_KEY, "anthropic-version": "2023-06-01"},
                    json={"model": "claude-sonnet-4-6", "max_tokens": 1024, "messages": [{"role": "user", "content": message}]},
                )
                data = response.json()
                
                if "error" in data:
                    error_type = data["error"].get("type", "unknown")
                    if error_type == "overloaded_error" and attempt < max_retries - 1:
                        wait = 2 ** attempt
                        print(f"[RETRY] API overloaded, waiting {wait}s... (attempt {attempt+1}/{max_retries})")
                        await asyncio.sleep(wait)
                        continue
                    raise HTTPException(status_code=503, detail=f"API Error: {data['error']['message']}")
                
                if "content" not in data or not data["content"]:
                    raise HTTPException(status_code=500, detail="Invalid response")
                
                return data["content"][0]["text"]
        except asyncio.TimeoutError:
            if attempt < max_retries - 1:
                await asyncio.sleep(2 ** attempt)
                continue
            raise HTTPException(status_code=504, detail="Request timeout")

VALID_API_KEYS = {"sk-peter-demo": "free", "sk-peter-pro": "pro"}

@app.post("/api/chat")
async def chat(request: Request):
    api_key = request.headers.get("x-api-key", "").strip()
    if not api_key:
        raise HTTPException(status_code=401, detail="Missing x-api-key")
    if api_key not in VALID_API_KEYS:
        raise HTTPException(status_code=401, detail="Invalid key")
    
    body = await request.json()
    response = await call_claude(body["message"])
    return {"response": response, "model": "claude-sonnet-4-6", "tier": VALID_API_KEYS[api_key]}

@app.get("/health")
async def health():
    return {"status": "ok"}

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8001)

# ============ AUTONOMOUS AGENT ENDPOINTS ============

from autonomous_executor import executor

@app.post("/api/autonomous/plan")
async def plan_autonomous_task(request: Request):
    """Plan task steps using Claude"""
    api_key = request.headers.get("x-api-key", "").strip()
    if not api_key or api_key not in VALID_API_KEYS:
        raise HTTPException(status_code=401, detail="Invalid API key")
    
    body = await request.json()
    user_request = body.get("request")
    user_id = body.get("user_id", api_key)
    
    result = await executor.plan_task(user_request, user_id)
    return result

@app.post("/api/autonomous/execute/{task_id}")
async def execute_autonomous_task(task_id: str, request: Request):
    """Execute task via OpenClaw"""
    api_key = request.headers.get("x-api-key", "").strip()
    if not api_key or api_key not in VALID_API_KEYS:
        raise HTTPException(status_code=401, detail="Invalid API key")
    
    result = await executor.execute_task(task_id)
    return result

@app.get("/api/autonomous/task/{task_id}")
async def get_autonomous_task(task_id: str, request: Request):
    """Get task status"""
    api_key = request.headers.get("x-api-key", "").strip()
    if not api_key or api_key not in VALID_API_KEYS:
        raise HTTPException(status_code=401, detail="Invalid API key")
    
    result = executor.get_task_status(task_id)
    return result
